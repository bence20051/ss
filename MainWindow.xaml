<Window x:Class="InformatikaiEszkozok_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Termékek karbantartása"
        Height="450"
        Width="800"
        Loaded="Window_Loaded">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- BAL: LISTA -->
        <GroupBox Header="Termékek"
                  Grid.Column="0"
                  Grid.RowSpan="2"
                  Margin="0,0,10,0">

            <ListBox x:Name="lbTermekek"
                     DisplayMemberPath="Nev"
                     SelectionChanged="lbTermekek_SelectionChanged"/>
        </GroupBox>

        <!-- JOBB: ADATOK -->
        <GroupBox Header="Termék adatai"
                  Grid.Column="1"
                  Grid.Row="0">

            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="Név:" Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                <TextBox x:Name="txtNev" Grid.Row="0" Grid.Column="1" Margin="0,3"/>

                <Label Content="Leírás:" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                <TextBox x:Name="txtLeiras" Grid.Row="1" Grid.Column="1" Margin="0,3"/>

                <Label Content="Egységár:" Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                <TextBox x:Name="txtEgysegar" Grid.Row="2" Grid.Column="1" Margin="0,3"/>

                <Label Content="Készlet:" Grid.Row="3" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                <TextBox x:Name="txtKeszlet" Grid.Row="3" Grid.Column="1" Margin="0,3"/>

                <Label Content="Elérhető:" Grid.Row="4" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                <TextBox x:Name="txtElerheto" Grid.Row="4" Grid.Column="1" Margin="0,3"/>

                <Label Content="Képfájlnév:" Grid.Row="5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                <TextBox x:Name="txtKepFajlnev" Grid.Row="5" Grid.Column="1" Margin="0,3"/>
            </Grid>
        </GroupBox>

        <!-- GOMBOK -->
        <Grid Grid.Column="1" Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Content="Módosítás" Grid.Column="0" Margin="5" Click="btnModositas_Click"/>
            <Button Content="Törlés" Grid.Column="1" Margin="5" Click="btnTorles_Click"/>
            <Button Content="Új felvitel" Grid.Column="2" Margin="5" Click="btnUj_Click"/>
            <Button Content="Kilépés" Grid.Column="3" Margin="5" Click="btnKilepes_Click"/>
        </Grid>
    </Grid>
</Window>